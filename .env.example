# MongoDB Atlas connection string (use process.env.MONGO_URI in app — do not commit real credentials)
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>/<dbname>?retryWrites=true&w=majority

# JWT
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=7d

# Server
PORT=5000

# Cloudinary (image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Optional folder prefix for uploads
# CLOUDINARY_FOLDER=tracelink/items
